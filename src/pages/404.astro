---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found - Analyzing Alpha" description="The page you're looking for doesn't exist.">
  <section class="mx-auto max-w-3xl px-6 py-24 text-center">
    <h1 class="text-6xl font-bold">404</h1>
    <p class="mt-4 text-lg text-text-muted">The page you're looking for doesn't exist.</p>
    <a href="/" class="mt-8 inline-block text-accent hover:text-accent-hover transition-colors">
      &larr; Back to home
    </a>
  </section>
</BaseLayout>
