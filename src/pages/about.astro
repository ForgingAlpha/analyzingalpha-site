---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About - Analyzing Alpha"
  description="About Leo Smigel and Analyzing Alpha."
>
  <article class="mx-auto max-w-3xl px-6 py-16">
    <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">About</h1>
    <div class="prose prose-invert prose-gray mt-8 max-w-none">
      <p>
        Hi, I'm Leo Smigel. I write about algorithmic trading, quantitative finance,
        and building trading systems with AI.
      </p>
      <p>
        Analyzing Alpha is where I share research, code, and ideas at the intersection
        of artificial intelligence and financial markets — with a focus on tokenized assets
        and systematic strategies.
      </p>
    </div>
  </article>
</BaseLayout>
