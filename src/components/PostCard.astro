---
import FormattedDate from './FormattedDate.astro';

interface Props {
  title: string;
  description: string;
  publishDate: Date;
  slug: string;
  tags?: string[];
}

const { title, description, publishDate, slug, tags = [] } = Astro.props;
---

<article class="py-6">
  <a href={`/blog/${slug}/`} class="group block">
    <h2 class="text-xl font-semibold text-text group-hover:text-accent transition-colors">
      {title}
    </h2>
    <div class="mt-1 text-sm text-text-muted">
      <FormattedDate date={publishDate} />
    </div>
    <p class="mt-2 text-text-muted">{description}</p>
    {tags.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-2">
        {tags.map((tag) => (
          <span class="rounded-full bg-surface px-2.5 py-0.5 text-xs text-text-muted">
            {tag}
          </span>
        ))}
      </div>
    )}
  </a>
</article>
