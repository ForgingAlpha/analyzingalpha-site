---
const navLinks = [
  { href: '/blog/', label: 'Blog' },
  { href: '/about/', label: 'About' },
];
---

<header class="border-b border-border">
  <nav class="mx-auto flex max-w-3xl items-center justify-between px-6 py-4">
    <a href="/" class="text-lg font-bold text-text hover:text-accent">
      Analyzing Alpha
    </a>
    <ul class="flex gap-6">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="text-sm text-text-muted hover:text-text transition-colors"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
